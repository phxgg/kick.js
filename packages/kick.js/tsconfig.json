{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "declarationMap": false,
    "removeComments": false,
    "isolatedModules": true,
    "sourceMap": false,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["./src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
