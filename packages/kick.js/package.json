{
  "name": "@phxgg/kick.js",
  "version": "0.6.0",
  "description": "JavaScript/TypeScript client for the Kick.com public API.",
  "license": "MIT",
  "author": "phxgg",
  "homepage": "https://github.com/phxgg/kick.js#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/phxgg/kick.js.git",
    "directory": "packages/kick.js"
  },
  "bugs": {
    "url": "https://github.com/phxgg/kick.js/issues"
  },
  "keywords": [
    "kick",
    "kick.com",
    "kick-api",
    "api",
    "client",
    "sdk",
    "typescript",
    "javascript",
    "streaming",
    "live-streaming",
    "webhook",
    "oauth"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "build": "npm run clean && tsc -p tsconfig.json",
    "type:check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
