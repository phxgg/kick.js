{
  "name": "kick-js-example-express",
  "version": "1.0.0",
  "description": "Example Express app consuming @phxgg/kick.js.",
  "license": "MIT",
  "author": "phxgg",
  "main": "dist/app.js",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "clean": "rimraf tsconfig.tsbuildinfo ./dist",
    "dev": "tsx watch ./src/app.ts",
    "start": "node ./dist/app.js",
    "type:check": "tsc --noEmit",
    "build": "npm run clean && npm run type:check && swc src -d dist --copy-files --strip-leading-paths"
  },
  "dependencies": {
    "@phxgg/kick.js": "*",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cron": "^4.4.0",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1",
    "ms": "^2.1.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-oauth2": "^1.8.0",
    "ulid": "^3.0.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-oauth2": "^1.8.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
